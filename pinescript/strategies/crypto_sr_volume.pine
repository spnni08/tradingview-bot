//@version=5
// ════════════════════════════════════════════════════════════════════════
// WAVESCOUT — Strategie 2/4: crypto_sr_volume
// ════════════════════════════════════════════════════════════════════════
// Level-Definition über Volume Profile (VAL/VAH/POC) statt klassischer S&R.
//   Long  : Preis prallt am VAL ab UND RSI bestätigt KEINEN starken Abwärtstrend.
//   Short : Preis prallt am VAH ab UND RSI bestätigt KEINEN starken Aufwärtstrend.
//   Trendfilter: EMA200 wie bei Baseline.
// Sendet `strategy:"crypto_sr_volume"` an die /webhook-URL.
indicator("WAVESCOUT · crypto_sr_volume", overlay=true)

// ── Inputs ──────────────────────────────────────────────────────────────
vpLookback = input.int(288, "VP Lookback (Bars)", minval=50, maxval=1000)
vpBins     = input.int(50,  "VP Bins",            minval=10, maxval=100)
vpVaPct    = input.float(70,"Value Area %",       minval=50, maxval=95)
vpTolPct   = input.float(0.15,"Zone-Toleranz %",  minval=0.02, maxval=1.0)
rsiLen     = input.int(14,  "RSI Länge")
rsiNoDown  = input.int(40,  "Long: RSI muss > (kein starker Abwärtstrend)")
rsiNoUp    = input.int(60,  "Short: RSI muss < (kein starker Aufwärtstrend)")

// ── Indikatoren ─────────────────────────────────────────────────────────
rsi    = ta.rsi(close, rsiLen)
ema200 = ta.ema(close, 200)
ema50  = ta.ema(close, 50)
trendUp   = close > ema200
trendDown = close < ema200

// ── Volume Profile (POC / VAH / VAL über Lookback-Fenster) ──────────────
var float poc = na
var float vah = na
var float val = na
calcVP() =>
    hi = ta.highest(high, vpLookback)
    lo = ta.lowest(low,  vpLookback)
    binSize = (hi - lo) / vpBins
    float[] binVol = array.new_float(vpBins, 0.0)
    if binSize > 0
        for i = 0 to vpLookback - 1
            if not na(close[i]) and not na(volume[i])
                idx = math.min(vpBins - 1, math.max(0, int((close[i] - lo) / binSize)))
                array.set(binVol, idx, array.get(binVol, idx) + volume[i])
    pocIdx = 0
    pocVol = 0.0
    for i = 0 to vpBins - 1
        if array.get(binVol, i) > pocVol
            pocVol := array.get(binVol, i)
            pocIdx := i
    total = array.sum(binVol)
    target = total * vpVaPct / 100.0
    loIdx = pocIdx
    hiIdx = pocIdx
    acc = pocVol
    while acc < target and (loIdx > 0 or hiIdx < vpBins - 1)
        below = loIdx > 0 ? array.get(binVol, loIdx - 1) : -1.0
        above = hiIdx < vpBins - 1 ? array.get(binVol, hiIdx + 1) : -1.0
        if above >= below
            hiIdx := hiIdx + 1
            acc := acc + math.max(0.0, above)
        else
            loIdx := loIdx - 1
            acc := acc + math.max(0.0, below)
    [lo + (pocIdx + 0.5) * binSize, lo + (hiIdx + 1) * binSize, lo + loIdx * binSize]

[p, vh, vl] = calcVP()
poc := p
vah := vh
val := vl

// ── Zonen-Treffer (Preis innerhalb Toleranz am Level) ───────────────────
nearVAL = not na(val) and math.abs(close - val) / close * 100 <= vpTolPct
nearVAH = not na(vah) and math.abs(close - vah) / close * 100 <= vpTolPct
// "Abprall": Tief hat die Zone berührt, Schluss wieder darüber (Long) / umgekehrt.
bounceUp   = nearVAL and low  <= val and close > val
bounceDown = nearVAH and high >= vah and close < vah

longSig  = bounceUp   and rsi > rsiNoDown and trendUp
shortSig = bounceDown and rsi < rsiNoUp   and trendDown

// ── Payload ─────────────────────────────────────────────────────────────
f_payload(_dir, _trigger, _zone) =>
    a = "{"
    a := a + "\"strategy\":\"crypto_sr_volume\","
    a := a + "\"symbol\":\""    + syminfo.ticker          + "\","
    a := a + "\"direction\":\"" + _dir                    + "\","
    a := a + "\"action\":\""    + (_dir == "LONG" ? "BUY" : "SELL") + "\","
    a := a + "\"trigger\":\""   + _trigger                + "\","
    a := a + "\"timeframe\":\"" + timeframe.period         + "\","
    a := a + "\"price\":"       + str.tostring(close)      + ","
    a := a + "\"rsi\":"         + str.tostring(rsi)        + ","
    a := a + "\"ema50\":"       + str.tostring(ema50)      + ","
    a := a + "\"ema200\":"      + str.tostring(ema200)     + ","
    a := a + "\"poc\":"         + (na(poc) ? "null" : str.tostring(poc)) + ","
    a := a + "\"vah\":"         + (na(vah) ? "null" : str.tostring(vah)) + ","
    a := a + "\"val\":"         + (na(val) ? "null" : str.tostring(val)) + ","
    a := a + "\"vp_zone\":\""   + _zone                   + "\","
    a := a + "\"trend\":\""     + (trendUp ? "BULLISH" : "BEARISH") + "\","
    a := a + "\"timestamp\":\"" + str.tostring(time)       + "\""
    a := a + "}"
    a

if longSig
    alert(f_payload("LONG",  "VAL_BOUNCE", "VAL"), alert.freq_once_per_bar_close)
if shortSig
    alert(f_payload("SHORT", "VAH_BOUNCE", "VAH"), alert.freq_once_per_bar_close)

plot(poc, "POC", color=color.orange)
plot(vah, "VAH", color=color.red)
plot(val, "VAL", color=color.green)
plotshape(longSig,  style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.tiny)
plotshape(shortSig, style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.tiny)
